FROM rust:bookworm AS builder
WORKDIR /app

COPY . .
RUN cargo build --release -p hs-device-bridge-matter

FROM debian:bookworm-slim AS runtime
RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates \
    && rm -rf /var/lib/apt/lists/*

COPY --from=builder /app/target/release/hs-device-bridge-matter /usr/local/bin/hs-device-bridge-matter

ENTRYPOINT ["/usr/local/bin/hs-device-bridge-matter"]
